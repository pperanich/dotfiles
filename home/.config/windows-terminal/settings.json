                "icon": "ms-appx:///ProfileIcons/{61c54bbd-c2c6-5271-96e7-009a87ff44bf}.png",
                "background": "#012456",
                "elevate": true,
                "closeOnExit": "never",
                "antialiasingMode": "grayscale",
                "cursorColor": "#FFFFFF",
                "cursorShape": "bar",
                "snapOnInput": true,
                "useAcrylic": true,
                "opacity": 85
            }
        ]
    },
