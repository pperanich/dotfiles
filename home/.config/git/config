[filter "lfs"]
  clean = "git-lfs clean -- %f"
  process = "git-lfs filter-process"
  required = true
  smudge = "git-lfs smudge -- %f"

[protocol "file"]
  allow = "always"

[user]
name = Preston Peranich
email = pperanich@gmail.com

[includeIf "gitdir:~/Documents/repos/oss/"]
  path = "./oss.gitconfig"

[includeIf "gitdir:~/Documents/repos/work/"]
  path = "./work.gitconfig"

[includeIf "gitdir:~/.cache/uv/**"]
  path = "./lfs-fix.gitconfig"

[http "https://gitlab.jhuapl.edu/"]
sslCAInfo = /etc/ssl/certs/ca-certificates.crt

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection

[merge]
    conflictstyle = zdiff3
[credential "https://gitlab.sitcore.net"]
	helper = 
	helper = !/nix/store/gwm0q042mjybkbid3chx7qchb09lacgb-glab-1.56.0/bin/glab auth git-credential
