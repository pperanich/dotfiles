{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "model": "anthropic/claude-opus-4-5",
  "autoupdate": true,
  "share": "disabled",
  "plugin": [
    "opencode-gemini-auth@latest",
    "oh-my-opencode",
    "opencode-antigravity-auth@1.3.0"
  ],
  "provider": {
    "google": {
      "name": "Google",
      "models": {
        "antigravity-gemini-3-pro-high": {
          "name": "Gemini 3 Pro High (Antigravity)",
          "thinking": true,
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-gemini-3-pro-low": {
          "name": "Gemini 3 Pro Low (Antigravity)",
          "thinking": true,
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "attachment": true,
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "opal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OPAL",
      "options": {
        "baseURL": "https://opal.livelab.jhuapl.edu/v2"
      },
      "models": {
        "Qwen/Qwen3-Coder-30B-A3B-Instruct": {
          "name": "Qwen3-Coder-30B-A3B-Instruct"
        },
        "zai-org/GLM-4.5-Air-FP8": {
          "name": "GLM-4.5-Air-FP8"
        }
      }
    },
    "openai-enterprise": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI Enterprise",
      "options": {
        "baseURL": "https://aigateway.jhuapl.edu/v1"
      },
      "models": {
        "gpt-5-codex": {
          "name": "gpt-5-codex"
        },
        "gpt-4.1": {
          "name": "gpt-4.1"
        }
      }
    }
  }
}
