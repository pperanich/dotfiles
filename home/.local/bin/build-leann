#!/usr/bin/env bash
set -euo pipefail

project_name="$(basename "$(git rev-parse --show-toplevel)")"
mapfile -t files < <(git ls-files)

leann build "${project_name}-index" \
  --docs "${files[@]}" \
  --embedding-mode mlx \
  --embedding-model mlx-community/Qwen3-Embedding-0.6B-4bit-DWQ \
  --use-ast-chunking \
  --force

# leann build "${project_name}-index" \
#   --docs "${files[@]}" \
#   --embedding-mode openai \
#   --embedding-model intfloat/e5-large-v2 \
#   --embedding-api-base https://opal.livelab.jhuapl.edu/v2 \
#   --embedding-api-key "$OPAL_API_KEY" \
#   --use-ast-chunking \
#   --force

# If not installed, run `uv tool install leann-core --with leann --with astchunk`
