          "type": "application",
          "value": "/Applications/Obsidian.app"
        },
        {
          "key": "n",
          "type": "application",
          "value": "/System/Applications/Notes.app"
        }
      ]
    },
    {
      "key": "4",
      "label": "IDE",
      "type": "group",
      "actions": [
