{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/master/schema.bar.json",
  "monitor": 0,
  "font_family": "JetBrainsMono Nerd Font",
  "font_size": 13.0,
  "theme": {
    "palette": "Catppuccin",
    "name": "Mocha",
    "accent": "Blue"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "layout": {
          "enable": true
        },
        "focused_window": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Media": {
        "enable": true
      }
    },
    {
      "Cpu": {
        "enable": true,
        "label_prefix": "Icon",
        "data_refresh_interval": 5
      }
    },
    {
      "Network": {
        "enable": true,
        "show_activity": false,
        "show_total_activity": false,
        "label_prefix": "Icon"
      }
    },
    {
      "Battery": {
        "enable": true,
        "label_prefix": "Icon",
        "hide_on_full_charge": false
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "DayDateMonth"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    }
  ]
}
