Host *
  ForwardAgent no
  AddKeysToAgent yes
  IgnoreUnknown UseKeychain
  UseKeychain yes
  Compression no
  ServerAliveInterval 0
  ServerAliveCountMax 3
  HashKnownHosts no
  UserKnownHostsFile ~/.ssh/known_hosts
  ControlMaster no
  ControlPath ~/.ssh/master-%r@%n:%p
  ControlPersist no

Host *
  ForwardX11 yes

Include config.d/*
