    {
      "key": "5",
      "label": "Comms",
      "type": "group",
      "actions": [
        {
          "key": "s",
          "type": "application",
          "value": "/Applications/Slack.app"
        },
        {
          "key": "e",
          "type": "application",
          "value": "/Applications/Microsoft Outlook.app"
        },
        {
          "key": "z",
          "type": "application",
          "value": "/Applications/zoom.us.app"
        }
      ]
    },
    {
      "key": "6",
      "label": "Creative",
      "type": "group",
      "actions": [
        {
          "key": "g",
          "type": "application",
          "value": "/Applications/GIMP.app"
        },
        {
          "key": "b",
          "type": "application",
          "value": "/Applications/Blender.app"
        },
        {
          "key": "r",
          "type": "application",
          "value": "/Applications/REAPER.app"
        }
      ]
    },
    {
      "key": "7",
      "label": "Social",
      "type": "group",
      "actions": [
        {
          "key": "m",
          "type": "application",
          "value": "/System/Applications/Messages.app"
        },
        {
          "key": "d",
          "type": "application",
          "value": "/Applications/Discord.app"
        },
        {
          "key": "x",
          "type": "application",
          "value": "/Applications/Element.app"
        }
      ]
    },
    {
      "key": "u",
      "label": "Utils",
      "type": "group",
      "actions": [
        {
          "key": "f",
          "type": "application",
          "value": "/System/Library/CoreServices/Finder.app"
        },
        {
          "key": "m",
          "type": "application",
          "value": "/System/Applications/Music.app"
        },
        {
          "key": "p",
          "type": "application",
          "value": "/System/Applications/System Settings.app"
        },
        {
          "key": "a",
          "type": "application",
          "value": "/System/Applications/Utilities/Activity Monitor.app"
        }
      ]
    },
    {
      "key": "w",
      "label": "Window",
      "type": "group",
      "actions": [
        {
          "iconPath": "macwindow.on.rectangle",
          "key": "f",
          "label": "Floating",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace layout floating"
        },
        {
          "iconPath": "square.grid.2x2",
          "key": "t",
          "label": "Tiling",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace layout tiling"
        },
        {
          "iconPath": "rectangle.split.3x1",
          "key": "a",
          "label": "Accordion",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace layout accordion"
        },
        {
          "iconPath": "arrow.triangle.2.circlepath",
          "key": "h",
          "label": "Toggle Orientation",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace layout tiles horizontal vertical"
        },
        {
          "iconPath": "pip.fill",
          "key": "c",
          "label": "Center Float",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace layout floating && /opt/homebrew/bin/aerospace resize smart 800"
        },
        {
          "iconPath": "arrow.up.left.and.arrow.down.right",
          "key": "m",
          "label": "Fullscreen",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace fullscreen"
        },
        {
          "iconPath": "rectangle.inset.filled",
          "key": "n",
          "label": "Native Fullscreen",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace macos-native-fullscreen"
        },
        {
          "iconPath": "equal",
          "key": "b",
          "label": "Balance Sizes",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace balance-sizes"
        },
        {
          "iconPath": "arrow.up.backward.and.arrow.down.forward",
          "key": "r",
          "label": "Resize Mode",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace mode resize"
        },
        {
          "iconPath": "square.split.2x1",
          "key": "z",
          "label": "Flatten Tree",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace flatten-workspace-tree"
        },
        {
          "iconPath": "rectangle.on.rectangle",
          "key": "o",
          "label": "Move to Other Monitor",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace move-workspace-to-monitor --wrap-around next"
        },
        {
          "iconPath": "xmark.square",
          "key": "q",
          "label": "Close Window",
          "type": "command",
          "value": "/opt/homebrew/bin/aerospace close"
        },
        {
          "iconPath": "switch.2",
          "key": "p",
          "label": "Toggle Bar Profile",
          "type": "command",
          "value": "$HOME/.config/sketchybar/bin/toggle-profile.sh"
        }
      ]
    },
    {
      "iconPath": "moon.fill",
      "key": "l",
      "label": "Sleep Display",
      "type": "command",
      "value": "pmset displaysleepnow"
    }
  ],
  "type": "group"
}
