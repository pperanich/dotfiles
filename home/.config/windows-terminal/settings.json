{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "defaultProfile": "{159a785b-36c2-42fa-995e-8fbda647460f}",
    "alwaysShowTabs": true,
    "showTabsInTitlebar": true,
    "showTerminalTitleInTitlebar": true,
    "initialCols": 120,
    "initialRows": 30,
    "theme": "Catppuccin Mocha",
    "wordDelimiters": " ./\\()\"'-:,.;<>~!@#$%^&*|+=[]{}~?\u2764",
    "newTabMenu": [
        { "type": "remainingProfiles" }
    ],
    "keybindings": [
        { "keys": "ctrl+t", "command": "newTab" },
        { "keys": "ctrl+w", "command": null },
        { "keys": "ctrl+tab", "command": "nextTab" },
        { "keys": "ctrl+shift+tab", "command": "prevTab" },
        { "keys": "ctrl+shift+up", "command": "scrollUp" },
        { "keys": "ctrl+shift+down", "command": "scrollDown" },
        { "keys": "ctrl+shift+pgup", "command": "scrollUpPage" },
        { "keys": "ctrl+shift+pgdn", "command": "scrollDownPage" },
        { "keys": "alt+1", "command": { "action": "switchToTab", "index": 0 } },
        { "keys": "alt+2", "command": { "action": "switchToTab", "index": 1 } },
        { "keys": "alt+3", "command": { "action": "switchToTab", "index": 2 } },
        { "keys": "alt+4", "command": { "action": "switchToTab", "index": 3 } },
        { "keys": "alt+5", "command": { "action": "switchToTab", "index": 4 } },
        { "keys": "alt+6", "command": { "action": "switchToTab", "index": 5 } },
        { "keys": "alt+7", "command": { "action": "switchToTab", "index": 6 } },
        { "keys": "alt+8", "command": { "action": "switchToTab", "index": 7 } },
        { "keys": "alt+9", "command": { "action": "switchToTab", "index": 8 } },
        { "keys": "ctrl+shift+1", "command": { "action": "newTab", "index": 0 } },
        { "keys": "ctrl+shift+2", "command": { "action": "newTab", "index": 1 } },
        { "keys": "ctrl+shift+3", "command": { "action": "newTab", "index": 2 } },
        { "keys": "ctrl+shift+4", "command": { "action": "newTab", "index": 3 } }
    ],
    "profiles": {
        "defaults": {
            "colorScheme": "Catppuccin Mocha",
            "font": {
                "face": "Iosevka Nerd Font",
                "size": 14
            },
            "historySize": 9001,
            "padding": "0, 0, 0, 0"
        },
        "list": [
            {
                "guid": "{159a785b-36c2-42fa-995e-8fbda647460f}",
                "name": "NixOS",
                "commandline": "wsl.exe -d NixOS",
                "startingDirectory": "\\\\wsl$\\NixOS\\home\\pperanich",
                "icon": "ms-appdata:///roaming/nix.png",
                "tabTitle": "NixOS",
                "closeOnExit": "never",
                "antialiasingMode": "cleartype",
                "cursorColor": "#FFFFFF",
                "cursorShape": "filledBox",
                "intenseTextStyle": "none",
                "snapOnInput": false,
                "useAcrylic": false,
                "opacity": 100
            },
            {
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
